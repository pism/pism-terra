#!/bin/sh
#SBATCH --partition={{ queue | default("t2small") }}
#SBATCH --ntasks={{ ntasks | default(40) }}
#SBATCH --tasks-per-node={{ tasks | default(40) }}
#SBATCH --time={{ walltime | default("24:00:00") }}
#SBATCH --mail-type=BEGIN
#SBATCH --mail-type=END
#SBATCH --mail-type=FAIL
#SBATCH --output="{{ output_path }}/pism.%j"

module list

umask 007

cd $SLURM_SUBMIT_DIR

srun -l /bin/hostname | sort -n | awk '{print $2}' > ./nodes_$SLURM_JOBID

ulimit -l unlimited
ulimit -s unlimited
ulimit

mpirun -np  {{ ntasks | default(40) }} apptainer run ${container} pism
